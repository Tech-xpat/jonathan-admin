# ─────────────────────────────────────────────────────────────────────────────
# Jonathan Roumie World – Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Production: NEXT_PUBLIC_BASE_URL=https://jonromworld.com

# ── Firebase (Client SDK) ─────────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Your Apps → Web App
# Supports: Google Auth, Email Link Auth, Phone Auth, Anonymous Auth, Storage
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin SDK (Server-side only) ─────────────────────────────────────
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new private key
# Required for server-side auth verification and Firestore admin operations
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Keep the \n as literal \n — Next.js will handle the newline replacement
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Admin Access ──────────────────────────────────────────────────────────────
# Comma-separated list of Google email addresses that can access /admin and /bigadmin
# Admin auth supports: Google OAuth, Email Link (Passwordless)
# Example: NEXT_PUBLIC_ADMIN_EMAILS=you@gmail.com,partner@gmail.com
NEXT_PUBLIC_ADMIN_EMAILS=empiredigitalsworldwide@gmail.com,empiredigitalsceo@gmail.com

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret from Stripe CLI or Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Optional – for contact form and admin email links) ────────────────
# Uncomment and configure your email provider
# RESEND_API_KEY=re_...
# CONTACT_EMAIL=contact@jonromworld.com

# ── Authentication Methods ─────────────────────────────────────────────────────
# User Authentication (Dashboard):
#   - Google OAuth (Whitelisting via admin panel)
#   - Email Link Auth (Optional)
#   - Anonymous (Optional)
#
# Admin Authentication (/admin, /bigadmin):
#   - Google OAuth (Email restricted)
#   - Email Link Auth (Passwordless sign-in)
#   - Verification via Bearer token in API routes
